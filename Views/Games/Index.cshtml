@model IEnumerable<VintageGameStore.Models.Game>

<h1>Games List</h1>
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="mb-0">
        <a asp-action="Create" class="btn btn-primary">Add New Game</a>
    </p>
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="searchString" class="form-control me-2" placeholder="Search by title..." style="width: 250px;" />
        <button type="submit" class="btn btn-outline-success">Search</button>
        @if (!string.IsNullOrEmpty(Context.Request.Query["searchString"]))
        {
            <a asp-action="Index" class="btn btn-link text-decoration-none">Clear</a>
        }
    </form>
</div>

<table class="table table-dark table-striped table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Price</th>
            <th>Year</th>
            <th>Category</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.ReleaseYear</td>
                <td>@item.Category?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>